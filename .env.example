# Copy to .env and fill in. .env is gitignored.

# --- Macro data (required) ---
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# ECOS (Bank of Korea): https://ecos.bok.or.kr/api
ECOS_API_KEY=

# --- LLM Providers (set the one you use; project default = openai) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# --- Observability (optional) ---
# LangSmith free tier: 5,000 traces/month, 14d retention
# Sign up at https://smith.langchain.com → Settings → API Keys
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=db-gaps-agent
